{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/dhx-session-id-stamp.sh\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/dhx-routing.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/dhx-main-branch-warning.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/dhx-verify-drift-gate.sh\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/dhx-assessed-guard.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/dhx-read-guard.js\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/dhx-gsd-canonical-mirror-gate.sh\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/dhx-worktree-write-guard.sh\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/dhx-ui-vision-guard.sh\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/dhx-agent-leak-snapshot.sh\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/dhx-poll-guard.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/dhx-read-cache.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use-gh-issue-create.sh\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/dhx-milestone-close-blocker-pretooluse.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/dhx-merge-reminder.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/dhx-new-milestone-promote-reminder.sh\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/dhx-source-write-flag.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/dhx-write-cache.sh\""
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/dhx-context-gate.sh\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/dhx-execute-checkpoint.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/dhx-execute-review.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/dhx-audit-checkpoint.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/dhx-subagent-stop-sync-probe-marker.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/dhx-agent-leak-check.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/dhx-deferred-check.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/dhx-execute-stop-review.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/dhx-milestone-close-blocker-check.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/dhx-test-gate.sh\"",
            "timeout": 300
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/dhx-restart-plugins-stop.sh\"",
            "timeout": 2
          }
        ]
      }
    ]
  }
}
