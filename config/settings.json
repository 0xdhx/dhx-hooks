    "deny": [
      "Read(./.env*)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Bash(*|*taskkill*)",
      "Bash(get-shit-done-cc:*)",
      "Bash(*npm i*get-shit-done*)",
      "Bash(*npx*get-shit-done*)",
      "Bash(chmod -R 777 *)",
      "Bash(dd if=*)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(mkfs *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"require(require('path').join(require('os').homedir(),'.claude','hooks','gsd-check-update.js'))\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/dhx/.claude/hooks/gsd-session-state.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"require(require('path').join(require('os').homedir(),'.claude','hooks','gsd-context-monitor.js'))\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"require(require('path').join(require('os').homedir(),'.claude','scripts','fix-gsd-ccs-paths.js'))\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/dhx/.claude/hooks/gsd-phase-boundary.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "\"/home/dhx/.nvm/versions/node/v22.22.2/bin/node\" \"$HOME/.claude/hooks/gsd-read-injection-scanner.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"/home/dhx/.nvm/versions/node/v22.22.2/bin/node\" \"$HOME/.claude/hooks/gsd-prompt-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/dhx/repos/hooks/.inactive/test-pretooluse-agent.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/dhx/.claude/hooks/gsd-validate-commit.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node \"$HOME/.claude/hooks/statusline-wrapper.js\"",
    "refreshInterval": 60
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "document-skills@anthropic-agent-skills": true,
    "dhx@dhx-local": true
  },
  "extraKnownMarketplaces": {
    "dhx-local": {
      "source": {
        "source": "directory",
        "path": "/home/dhx/repos/hooks/dhx-plugin"
      }
    }
  },
  "effortLevel": "xhigh",
  "awaySummaryEnabled": true,
  "tui": "fullscreen",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true,
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": false,
  "voiceEnabled": true
}
